# =========================================================
# PMIS Frontend - Codex ignore
# Purpose: stop Codex/VS Code agent from reading junk context
# =========================================================

# Dependencies
node_modules/
**/node_modules/
jspm_packages/
web_modules/

# Large lock/package manager files
package-lock.json
yarn.lock
pnpm-lock.yaml

# Next.js build output
.next/
.next/cache/
out/
dist/
build/
.vercel/
.turbo/
.swc/
*.tsbuildinfo

# Cache
.cache/
**/.cache/
.npm/
.eslintcache
.stylelintcache
.parcel-cache/
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Env / secrets
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
private/

# Logs / runtime
*.log
**/*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
pids/
*.pid
*.pid.lock

# Generated user files / media
public/uploads/
public/generated/
public/exports/
uploads/
exports/
reports/
generated/
screenshots/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.vscode-test/
.idea/

# Local temp / cleanup
_tmp/
tmp/
temp/
_cleanup_quarantine_*
codex/