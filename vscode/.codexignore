# =========================================================
# PMIS Backend - Codex ignore
# Purpose: stop Codex/VS Code agent from reading junk context
# =========================================================

# Dependencies
node_modules/
**/node_modules/
jspm_packages/
web_modules/

# Large lock/package manager files
package-lock.json
yarn.lock
pnpm-lock.yaml

# Env / secrets
.env
.env.*
!.env.example
src/config.env
src/config/config.json
src/config/google-service-account-file.json
src/config/db_seed.json

# Keys / certificates / private material
*.pem
*.key
*.crt
*.p12
*.pfx
ssl/
src/ssl/
secrets/
private/

# Logs / runtime
*.log
**/*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
secure-logs/
src/secure-logs/
pids/
*.pid
*.pid.lock

# Build / coverage / cache
.cache/
**/.cache/
.npm/
coverage/
.nyc_output/
dist/
build/
lib-cov/
.tmp/
tmp/
temp/
_tmp/

# Puppeteer / browser cache
.cache/puppeteer/
**/.cache/puppeteer/

# Generated uploads / exports / reports
uploads/
src/uploads/
public/uploads/
storage/
exports/
reports/
generated/
generated-pdfs/
invoices/
attachments/

# Docker/local artifacts
.docker/
docker-data/
docker-volumes/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local Codex scratch
codex/